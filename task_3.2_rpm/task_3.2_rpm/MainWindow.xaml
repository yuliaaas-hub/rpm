<Window x:Class="task_3._2_rpm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:task_3._2_rpm"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <ComboBox Name="comboBox" Margin="10"
               SelectionChanged="comboBox_SelectedIndexChanged">
            <TextBlock>Красный</TextBlock>
            <TextBlock>Зеленый</TextBlock>
            <TextBlock>Синий</TextBlock>
        </ComboBox>
        <Border Grid.Row="1" 
             BorderBrush="Gray" 
             BorderThickness="1" 
             Background="WhiteSmoke">
            <StackPanel x:Name="ShapesPanel" 
                     Orientation="Horizontal" 
                     HorizontalAlignment="Center" 
                     VerticalAlignment="Center"/>
        </Border>


    </Grid>
</Window>
